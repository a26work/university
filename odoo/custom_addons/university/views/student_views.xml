<odoo>
  <!-- Student Views -->
  <record id="view_student_tree" model="ir.ui.view">
    <field name="name">university.student.tree</field>
    <field name="model">university.student</field>
    <field name="arch" type="xml">
      <tree>
        <field name="level"/>
        <field name="user_id"/>
        <field name="program_id"/>
      </tree>
    </field>
  </record>

  <record id="view_student_form" model="ir.ui.view">
    <field name="name">university.student.form</field>
    <field name="model">university.student</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="level"/>
            <field name="user_id"/>
            <field name="program_id"/>
            <field name="evaluation_ids"  widget="many2many_tags"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_student_search" model="ir.ui.view">
    <field name="name">university.student.search</field>
    <field name="model">university.student</field>
    <field name="arch" type="xml">
      <search>
        <field name="level"/>
        <field name="program_id"/>
      </search>
    </field>
  </record>

  <record id="action_student" model="ir.actions.act_window">
    <field name="name">Students</field>
    <field name="res_model">university.student</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="university_people_menu" name="University People" parent="university_root_menu" sequence="20"/>
  <menuitem id="university_student_menu" name="Students" parent="university_people_menu" action="action_student"/>
</odoo>
