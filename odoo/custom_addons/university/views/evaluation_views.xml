<odoo>
  <!-- Evaluation Views -->
  <record id="view_evaluation_tree" model="ir.ui.view">
    <field name="name">university.evaluation.tree</field>
    <field name="model">university.evaluation</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="student_id"/>
        <field name="score"/>
      </tree>
    </field>
  </record>

  <record id="view_evaluation_form" model="ir.ui.view">
    <field name="name">university.evaluation.form</field>
    <field name="model">university.evaluation</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="student_id"/>
            <field name="score"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_evaluation_search" model="ir.ui.view">
    <field name="name">university.evaluation.search</field>
    <field name="model">university.evaluation</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="student_id"/>
      </search>
    </field>
  </record>

  <record id="action_evaluation" model="ir.actions.act_window">
    <field name="name">Evaluations</field>
    <field name="res_model">university.evaluation</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="university_evaluation_menu" name="Evaluations" parent="university_academic_menu" action="action_evaluation"/>
</odoo>
