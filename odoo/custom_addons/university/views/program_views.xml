<odoo>
  <record id="view_program_tree" model="ir.ui.view">
    <field name="name">university.program.tree</field>
    <field name="model">university.program</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="department_id"/>
      </tree>
    </field>
  </record>

  <record id="view_program_form" model="ir.ui.view">
    <field name="name">university.program.form</field>
    <field name="model">university.program</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="department_id"/>
            <field name="course_ids" widget="many2many_tags"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_program_search" model="ir.ui.view">
    <field name="name">university.program.search</field>
    <field name="model">university.program</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="department_id"/>
      </search>
    </field>
  </record>

  <record id="action_program" model="ir.actions.act_window">
    <field name="name">Programs</field>
    <field name="res_model">university.program</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="university_program_menu" name="Programs" parent="university_academic_menu" action="action_program"/>
</odoo>

